<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.tain.co-writer-bot-weekly-report</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-c</string>
        <string>export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"; cd /Users/cony/dev/my-bot/co-writer-bot; set -a; [ -f .env ] &amp;&amp; source .env; set +a; exec python3 -m bot.router_report --days 7</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/cony/dev/my-bot/co-writer-bot</string>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>1</integer>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/cony/dev/my-bot/co-writer-bot/logs/weekly-report.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/cony/dev/my-bot/co-writer-bot/logs/weekly-report.err.log</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
