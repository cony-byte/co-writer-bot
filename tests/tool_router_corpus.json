        "attachments": [{"id": "F003", "name": "look.jpg", "mimetype": "image/jpeg"}]
      },
      "expected": {
        "type_oneof": ["tool_call", "tool_calls"],
        "tool_oneof": ["generate_reference_image", "replace_reference_image"],
