    {
      "id": "grid-fix-no-clarify",
      "text": "1화 스토리보드 이미지가 이상하니까 고쳐줘",
      "ctx": {
        "tracked_work": "저는 연프 출연진이 아닌데요 !",
        "tracked_episode": 1,
        "sb_stage": 2
      },
      "expected": {
        "type_oneof": ["tool_call", "tool_calls"],
        "tool": "generate_storyboard_grid",
