# Slack (README의 manifest로 앱 생성 후 발급)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ── Anthropic 인증 ─────────────────────────────────────────────
# 팀 클로드(구독)로 돌리는 경우: 아무것도 설정하지 마세요.
#   `ant auth login`으로 팀 계정 로그인만 하면 SDK가 프로필을 자동 인식합니다.
#   ⚠️ ANTHROPIC_API_KEY를 빈 값으로라도 두면 프로필을 가려버려 인증이 깨집니다.
#
# API 키로 돌리는 경우에만 아래 주석 해제:
# ANTHROPIC_API_KEY=sk-ant-...

# 선택
# COWRITER_MODEL=claude-opus-4-8
# COWRITER_MAX_TOKENS=16000
# COWRITER_REFERENCE_DIR=/path/to/story-v1-scripts/reference
