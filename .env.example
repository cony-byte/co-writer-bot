# Slack (README의 manifest로 앱 생성 후 발급)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ── Anthropic 인증 ─────────────────────────────────────────────
# 기본(agent 백엔드): 아무것도 설정하지 마세요.
#   이 머신에 Claude Code가 팀 계정으로 로그인돼 있으면 그 연결을 그대로 씁니다.
#
# API 키로 직접 호출하려면 (COWRITER_BACKEND=api):
# COWRITER_BACKEND=api
# ANTHROPIC_API_KEY=sk-ant-...   # 또는 `ant auth login` 프로필

# 선택
# COWRITER_AGENT_MODEL=opus      # agent 백엔드 모델 ("" = Claude Code 기본 모델)
# COWRITER_MODEL=claude-opus-4-8 # api 백엔드 모델
# COWRITER_MAX_TOKENS=16000
# COWRITER_REFERENCE_DIR=/path/to/story-v1-scripts/reference
