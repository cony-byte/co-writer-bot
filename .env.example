# ── Slack (필수) — @co-writer 정체성 유지 (HANDOFF §1-1) ──
# 이 봇은 co-writer-bot의 Slack 앱/토큰을 그대로 씀. storyboard-bot용 별도 앱은 폐기.
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ── Anthropic 인증 ─────────────────────────────────────────────
# 기본(agent 백엔드): 아무것도 설정하지 마세요.
#   이 머신에 Claude Code가 팀 계정으로 로그인돼 있으면 그 연결을 그대로 씁니다.
#
# API 키로 직접 호출하려면 (백엔드는 co-writer/storyboard 각자 별도 스위치 — HANDOFF §3-5 리스크 3:
# 두 생성 백엔드는 절대 하나로 합치지 않음):
# COWRITER_BACKEND=api           # co-writer 쪽
# SB_BACKEND=api                 # storyboard 쪽
# ANTHROPIC_API_KEY=sk-ant-...   # 또는 `ant auth login` 프로필 — 두 백엔드가 공유

# ── 구글 시트 스토리 바이블 (선택, co-writer/storyboard 공유) ──
# 입력은 슬랙 봇, 열람은 구글 시트. google_sheet/Code.gs를 시트에 배포하고
# 나온 웹앱 URL과 그 스크립트에 넣은 SECRET을 여기에. 둘 다 있어야 바이블 기능 활성.
# SHEET_WEBAPP_URL=https://script.google.com/macros/s/xxxx/exec
# SHEET_SECRET=긴_무작위_문자열_Code.gs와_동일하게

# ── Notion (선택, co-writer/storyboard 공유) ──
# NOTION_TOKEN=ntn_...
# NOTION_PAGES='{"별칭":"page_id"}'

# ── OpenRouter 이미지 생성 (상세 콘티 → 스틸컷, storyboard 3단계 [이미지]에 필요) ──
# openrouter.ai/keys 에서 발급. 없으면 이미지 기능만 비활성(콘티까지는 동작).
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_IMAGE_MODEL=openai/gpt-image-2   # = "GPT 이미지 2.0" (기본값)
# OPENROUTER_IMAGE_QUALITY=low   # auto|low|medium|high — 기본 low(크레딧 절약). high는 장당 최대 10배+ 비쌈
# OPENROUTER_IMAGE_ASPECT=9:16   # co-writer 쪽 표기
# OPENROUTER_PANEL_ASPECT=16:9   # storyboard 쪽 표기
# OPENROUTER_GRID_COLS=6

# ── 인물 고정이미지 단일 소스 (visual-pipeline과 공유) ──
# storyboard-bot이 참조 얼굴을 여기서 읽음: <root>/<작품>/fixed-images/<인물>/<파일>
# 작품명이 달라도 노션 page_id로 브리지. 기본값 = 내장 data/projects. 외부 경로 쓸 때만 오버라이드.
# FIXED_IMAGES_ROOT=/path/to/projects

# ── 이미지 백엔드 선택 (기본 openrouter, OpenRouter는 그대로 둠) ──
# IMAGE_BACKEND=higgsfield 로 바꾸면 아래 Higgsfield로 스틸컷 생성 (bot/config.py가 읽음).
# 주의: 아래 두 Higgsfield 키 쌍은 이름이 비슷하지만 서로 다른 기능/모듈이 씀 — 하나가 다른
# 하나의 레거시 이름이 아님. 계정이 같아도 둘 다 따로 설정해야 각 기능이 동작.
# IMAGE_BACKEND=openrouter
# ── Higgsfield: 스틸컷 이미지 백엔드 (bot/higgsfield_image.py, config.HIGGSFIELD_*) ──
# HIGGSFIELD_API_KEY=...
# HIGGSFIELD_SECRET=...                # key+secret 쌍 쓰는 계정만
# HIGGSFIELD_BASE_URL=https://api.higgsfield.ai
# HIGGSFIELD_IMAGE_MODEL=gpt-image     # 계정에서 쓰는 모델명으로
# ── Higgsfield: 영상화 (bot/higgsfield_video.py, os.environ 직접 읽음, storyboard 5단계) ──
# HF_API_KEY=...
# HF_API_SECRET=...                    # 또는 HF_KEY 단일값

# ── LLM 최대 대기(초) ──
# COWRITER_AGENT_TIMEOUT=600    # co-writer 쪽, 기본 150s로 자주 타임아웃 나 상향
# SB_AGENT_TIMEOUT=600          # storyboard 쪽, 상세 콘티가 길어서 기본 300s로 자주 타임아웃 나 상향

# 선택
# COWRITER_AGENT_MODEL=opus      # co-writer agent 백엔드 모델 ("" = Claude Code 기본 모델)
# COWRITER_MODEL=claude-opus-4-8 # co-writer api 백엔드 모델
# COWRITER_MAX_TOKENS=16000
# COWRITER_REFERENCE_DIR=/path/to/story-v1-scripts/reference
# COWRITER_SHEET_TTL=300         # 시트 바이블 캐시 (초)
# COWRITER_VERIFY_GATE=1         # 생성 검증 관문(3단계 감사) 기본 ON. 0=끔. 요청별 '검증생략'/'검증'으로도 제어
